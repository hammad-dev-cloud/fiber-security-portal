# =====================================================================
# Fiber Security Portal — Backend Environment Variables
# Copy this file to ".env" and fill in your real credentials.
# =====================================================================

# --- Supabase ---
# Get these from: https://app.supabase.com → Your Project → Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_KEY=YOUR-SERVICE-ROLE-KEY-HERE

# --- JWT ---
# Generate a long random string. You can run:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-very-long-random-string-at-least-64-chars-long
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Email (SMTP) ---
# Gmail example. For Gmail, create an "App Password":
#   https://myaccount.google.com/apppasswords
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=your.email@gmail.com
MAIL_FROM_NAME=Fiber Security Portal
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# --- Security ---
# Block an IP after N failed login attempts within the window (seconds)
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_WINDOW_SECONDS=300
BRUTE_FORCE_LOCKOUT_SECONDS=900

# --- Router Monitoring ---
ROUTER_PING_TIMEOUT_SECONDS=2
ROUTER_MONITOR_INTERVAL_SECONDS=60
